{
  "name": "vibe-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "dist:exe": "npm run build && electron-builder --win --dir"
  },
  "build": {
    "appId": "com.lifelink.app",
    "productName": "LifeLink Organ Coordination",
    "directories": {
      "output": "dist-exe"
    },
    "win": {
      "target": "portable",
      "icon": "public/logo.png"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "vite": "^5.3.1",
    "wait-on": "^9.0.4"
  }
}
